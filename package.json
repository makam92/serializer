{
  "name": "serializer",
  "version": "0.1.0",
  "description": "Play music to multiple speakers (Bluetooth, AirPlay, wired, built-in) at the same time, in sync.",
  "main": "src/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.serializer.app",
    "productName": "Serializer",
    "npmRebuild": false,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!.claude/**",
      "!build/**",
      "!docs/**",
      "!dist/**",
      "!**/*.md",
      "!**/*.node",
      "!**/{.DS_Store,.git,.gitignore,.npmrc}"
    ],
    "mac": {
      "category": "public.app-category.music",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Serializer uses the microphone to read your audio device names, auto-measure speaker latency, and capture live input.",
        "NSLocalNetworkUsageDescription": "Serializer discovers and streams to Sonos and AirPlay speakers on your local network.",
        "NSBonjourServices": [
          "_sonos._tcp",
          "_airplay._tcp",
          "_raop._tcp"
        ]
      }
    },
    "dmg": {
      "title": "Serializer ${version}"
    }
  },
  "keywords": [
    "audio",
    "multi-speaker",
    "multiroom",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "node-airtunes2": "^2.5.0"
  },
  "allowScripts": {
    "electron@33.4.11": true,
    "node-airtunes2@2.5.0": true,
    "protobufjs@6.11.6": true
  }
}
