<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Electron / V8 need JIT + executable memory under the hardened runtime -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- node-airtunes2 ships a native module; allow loading it even if differently signed -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- Microphone: device-label unlock, Auto-sync, Live capture -->
  <key>com.apple.security.device.audio-input</key>
  <true/>
  <!-- LAN: discover (mDNS) + stream to Sonos/AirPlay, and run the local HTTP stream server -->
  <key>com.apple.security.network.client</key>
  <true/>
  <key>com.apple.security.network.server</key>
  <true/>
</dict>
</plist>
